<?xml version="1.0" encoding="UTF-8"?>

<jasperReport
    name="quotation_report"
    xmlns="http://jasperreports.sourceforge.net/jasperreports"
    xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
    xsi:schemaLocation="http://jasperreports.sourceforge.net/jasperreports
                        http://jasperreports.sourceforge.net/xsd/jasperreport.xsd"
    pageWidth="595"
    pageHeight="842"
    columnWidth="555"
    leftMargin="20"
    rightMargin="20"
    topMargin="20"
    bottomMargin="20">

    <!-- PARAMETER -->
    <parameter name="quotationId" class="java.lang.Long"/>

    <!-- QUERY -->
    <queryString>
        <![CDATA[
            SELECT product_name, price, quantity, (price * quantity) AS total
            FROM quotation_item
            WHERE quotation_id = $P{quotationId}
        ]]>
    </queryString>

    <!-- FIELDS -->
    <field name="product_name" class="java.lang.String"/>
    <field name="price" class="java.lang.Double"/>
    <field name="quantity" class="java.lang.Integer"/>
    <field name="total" class="java.lang.Double"/>

    <!-- ✅ GRAND TOTAL VARIABLE -->
    <variable name="grandTotal" class="java.lang.Double" calculation="Sum">
        <variableExpression><![CDATA[$F{total}]]></variableExpression>
    </variable>

    <!-- TITLE -->
    <title>
        <band height="60">
            <staticText>
                <reportElement x="180" y="10" width="200" height="30"/>
                <textElement textAlignment="Center">
                    <font size="18" isBold="true"/>
                </textElement>
                <text><![CDATA[QUOTATION]]></text>
            </staticText>
        </band>
    </title>

    <!-- COLUMN HEADER -->
    <columnHeader>
        <band height="25">

            <staticText>
                <reportElement x="0" y="0" width="200" height="25"/>
                <box><pen lineWidth="1.0"/></box>
                <text><![CDATA[Product]]></text>
            </staticText>

            <staticText>
                <reportElement x="200" y="0" width="100" height="25"/>
                <box><pen lineWidth="1.0"/></box>
                <text><![CDATA[Price]]></text>
            </staticText>

            <staticText>
                <reportElement x="300" y="0" width="100" height="25"/>
                <box><pen lineWidth="1.0"/></box>
                <text><![CDATA[Qty]]></text>
            </staticText>

            <staticText>
                <reportElement x="400" y="0" width="155" height="25"/>
                <box><pen lineWidth="1.0"/></box>
                <text><![CDATA[Total]]></text>
            </staticText>

        </band>
    </columnHeader>

    <!-- DETAIL -->
    <detail>
        <band height="25">

            <textField>
                <reportElement x="0" y="0" width="200" height="25"/>
                <box><pen lineWidth="0.5"/></box>
                <textFieldExpression><![CDATA[$F{product_name}]]></textFieldExpression>
            </textField>

            <textField>
                <reportElement x="200" y="0" width="100" height="25"/>
                <box><pen lineWidth="0.5"/></box>
                <textFieldExpression><![CDATA[$F{price}]]></textFieldExpression>
            </textField>

            <textField>
                <reportElement x="300" y="0" width="100" height="25"/>
                <box><pen lineWidth="0.5"/></box>
                <textFieldExpression><![CDATA[$F{quantity}]]></textFieldExpression>
            </textField>

            <textField>
                <reportElement x="400" y="0" width="155" height="25"/>
                <box><pen lineWidth="0.5"/></box>
                <textFieldExpression><![CDATA[$F{total}]]></textFieldExpression>
            </textField>

        </band>
    </detail>

    <!-- SUMMARY -->
    <summary>
        <band height="40">

            <staticText>
                <reportElement x="300" y="10" width="100" height="20"/>
                <textElement textAlignment="Right">
                    <font isBold="true"/>
                </textElement>
                <text><![CDATA[Grand Total:]]></text>
            </staticText>

            <textField>
                <reportElement x="400" y="10" width="155" height="20"/>
                <textElement textAlignment="Left">
                    <font isBold="true"/>
                </textElement>
                <textFieldExpression><![CDATA[$V{grandTotal}]]></textFieldExpression>
            </textField>

        </band>
    </summary>

</jasperReport>